# Copy to `sync-server/.env`. Used when running `npm run sync-server`.

# --- OpenAI (platform guidance proxy) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Apple App Store Server API (consumable verification) ---
# App Store Connect → Users and Access → Keys → In-App Purchase key (or generate API key with App Manager).
APP_STORE_ISSUER_ID=
APP_STORE_KEY_ID=
# Paste the full .p8 contents; replace newlines with \n for a single-line env value.
APP_STORE_PRIVATE_KEY=
# Must match the iOS app bundle id (see app.json expo.ios.bundleIdentifier).
IOS_BUNDLE_ID=com.aperture.mobile

# --- Google Play (consumable verify + consume) ---
# Service account JSON (single line) with Android Publisher access; link in Play Console → API access.
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
ANDROID_PACKAGE_NAME=com.aperture.mobile

# Map store product ids → credits granted per successful verification.
# Keys must match App Store Connect + Play Console product ids exactly.
IAP_PRODUCT_CREDITS_JSON={"com.aperture.mobile.credits_10":10,"com.aperture.mobile.credits_25":25,"com.aperture.mobile.credits_60":60}

PORT=8787
