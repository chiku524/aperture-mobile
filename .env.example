# --- Where does this file go? ---
# Git only ships `.env.example` (this file). You create your own `.env` next to the
# mobile app’s `package.json` (project root: aperture-mobile/.env), then restart Metro.
#
# Example (Windows/macOS/Linux, from project root):
#   copy .env.example .env     # Windows cmd
#   cp .env.example .env       # bash / macOS
#
# Never commit a real `.env` — it is gitignored.

# Inlined by Metro when present at `expo start` / EAS build time. Dev-only; do not ship secrets in release builds.
EXPO_PUBLIC_OPENAI_API_KEY=
